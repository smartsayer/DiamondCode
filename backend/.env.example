# Copy to .env and fill in values

# App
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://diamondcode:password@localhost:5432/diamondcode

# OpenWeather API (free tier works — https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_key_here

# Scoring weights — must sum to 1.0 (defaults set in config.py, override here if needed)
# WEIGHT_PARK_FACTOR=0.30
# WEIGHT_PITCHER=0.30
# WEIGHT_WEATHER=0.20
# WEIGHT_UMPIRE=0.10
# WEIGHT_BULLPEN=0.10
